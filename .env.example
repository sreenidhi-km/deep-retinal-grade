# Deep Retina Grade - Environment Configuration
# Copy this file to .env and customize values

# =============================================================================
# DEMO MODE
# =============================================================================
# Set to "true" to skip quality/uncertainty checks (for demos/testing)
# In production, should ALWAYS be "false"
DR_DEMO_MODE=false

# =============================================================================
# QUALITY ASSESSMENT THRESHOLDS
# =============================================================================
# Minimum quality score (0-1) before flagging RETAKE
# Lower = more permissive, Higher = stricter
DR_QUALITY_THRESHOLD=0.4

# =============================================================================
# UNCERTAINTY THRESHOLDS
# =============================================================================
# Maximum epistemic uncertainty before flagging REVIEW
# Higher = more permissive (fewer REVIEW flags)
DR_UNCERTAINTY_THRESHOLD=0.15

# Maximum entropy before flagging OOD (out-of-distribution)
# Higher = more permissive (fewer OOD flags)
DR_OOD_ENTROPY_THRESHOLD=1.5

# =============================================================================
# MC DROPOUT SETTINGS
# =============================================================================
# Number of MC Dropout samples for uncertainty estimation
# More samples = better uncertainty estimate but slower
# Recommended: 5 for fast inference, 20 for accurate uncertainty
DR_MC_SAMPLES=5

# =============================================================================
# MODEL SETTINGS
# =============================================================================
# Path to model checkpoint (relative to project root)
# If not set, defaults to models/efficientnet_b0_improved.pth
# DR_MODEL_PATH=models/efficientnet_b0_improved.pth

# =============================================================================
# LOGGING
# =============================================================================
# Set to "true" for verbose logging
DR_VERBOSE=false

# =============================================================================
# RATE LIMITING
# =============================================================================
# Maximum requests per window per IP address
DR_RATE_LIMIT_MAX=60

# Rate limit window in seconds
DR_RATE_LIMIT_WINDOW=60

# =============================================================================
# ENSEMBLE
# =============================================================================
# Set to "true" to enable multi-model ensemble prediction.
# Requires at least 2 model files in models/ matching the pattern
# models/efficientnet_b0_*.pth (e.g., efficientnet_b0_best.pth,
# efficientnet_b0_improved.pth, efficientnet_b0_tuned.pth).
#
# Models are discovered by globbing models/efficientnet_b0_*.pth and
# loaded in alphabetical order.  If fewer than 2 matching files exist
# at startup, ensemble mode is silently disabled and a warning is
# logged (single-model inference remains available at /predict).
#
# Predictions are combined via arithmetic averaging of softmax
# probabilities (equal weights) by default.
DR_ENSEMBLE_ENABLED=false

# =============================================================================
# CONFIDENCE THRESHOLD
# =============================================================================
# Minimum confidence before flagging REVIEW
DR_CONFIDENCE_THRESHOLD=0.6
