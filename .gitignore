# Deep Retina Grade - Git Ignore File

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual Environments
# =============================================================================
.venv/
venv/
ENV/
env/

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Data Files (Large - Do not commit)
# =============================================================================
data/
aptos2019-blindness-detection/
DDR Dataset/
B. Disease Grading/
messidor_data/
*.tif
*.zip
*.tar.gz
*.jpg
*.jpeg
*.png
!artifacts/*.png
!app/frontend/**/*.png

# =============================================================================
# Model Weights (Large - Store in releases or LFS)
# =============================================================================
models/*.pth
models/*.pt
models/*.h5
models/*.onnx
!models/.gitkeep

# =============================================================================
# Cache
# =============================================================================
cache/
.cache/
preprocessed_cache/
*.cache

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# Reports (Generated)
# =============================================================================
artifacts/reports/*.pdf

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.local
.env.*.local
*.env

# =============================================================================
# Node.js (Frontend)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build
app/frontend/dist/
app/frontend/build/

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# =============================================================================
# Review Materials (large generated PDFs and images)
# =============================================================================
review_materials/*.png
review_materials/*.jpg
review_materials/*.jpeg
review_materials/visual_summary.pdf

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.temp
